# ============================================================
# Environment Variables — CBC School Management System
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================
#
# Prerequisites:
# - Node.js >= 18.17.0
# - npm (comes with Node.js)
#
# Quick start:
#   1. cp .env.example .env.local
#   2. Fill in your Supabase project credentials
#   3. npm ci
#   4. npm run dev
# ============================================================

# ── Supabase (Required) ──────────────────────────────────────
# Get these from your Supabase project: Project Settings > API
# Frontend (public) — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend (secret) — NEVER expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase Storage (Optional) ─────────────────────────────
# Defaults to "school-assets" if not set
SUPABASE_STORAGE_BUCKET=school-assets

# ── Application (Required) ───────────────────────────────────
# Used for password reset links, callbacks, etc.
# No trailing slash. Example: https://school-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI / LLM Provider (Required for AI features) ────────────
# Choose provider: "openrouter" | "groq" | "deepseek"
AI_PROVIDER=openrouter

# OpenRouter (recommended)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=CBC-School-Management
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_MODEL_FAST=google/gemini-2.0-flash-001
OPENROUTER_MODEL_REASONING=anthropic/claude-3-opus-20240229
OPENROUTER_MODEL_FREE=google/gemini-2.0-flash-001

# Groq (alternative)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Deepseek (alternative)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_REASONING=deepseek-reasoner

# AI behaviour tuning
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_PROMPT_CHARS=30000
AI_MAX_OUTPUT_TOKENS=2048
AI_CACHE_TTL_SECONDS=21600
AI_AGENT_TIMEZONE=Africa/Nairobi
AI_ALLOW_FREE_MODEL_FALLBACK=false

# ── M-Pesa Daraja API (Optional — for v2 payment integration)─
# Get these from Safaricom Developer Portal: https://developer.safaricom.co.ke
# Set MPESA_ENV to "sandbox" for testing or "production" for live
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey
MPESA_C2B_RESPONSE_TYPE=Completed
MPESA_CALLBACK_BASE_URL=https://your-domain.com/api/mpesa/c2b

# M-Pesa: User IDs for system reconciliation
MPESA_DEFAULT_SCHOOL_ID=
MPESA_SYSTEM_USER_ID=

# ── Cloudinary Uploads (Optional) ────────────────────────────
# If set, /api/upload will use Cloudinary first and fall back to Supabase when unavailable.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Africa's Talking SMS/WhatsApp (Optional) ─────────────────
# Get these from: https://account.africastalking.com
# Set AT_ENV to "sandbox" for testing or "production" for live
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=your-sender-id
AT_ENV=sandbox

# ── Test / Seed Data (Optional) ──────────────────────────────
TEST_USER_PASSWORD=Test1234!
TEST_USER_EMAIL_DOMAIN=example.com

# ── Node Environment ────────────────────────────────────────
# Set automatically by Next.js (development / production)
# NODE_ENV=development

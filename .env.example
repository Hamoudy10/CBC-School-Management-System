# ============================================================
# Environment Variables — CBC School Management System
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase (Required) ──────────────────────────────────────
# Get these from your Supabase project: Project Settings > API
# Frontend (public) — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend (secret) — NEVER expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase Storage (Optional) ─────────────────────────────
# Defaults to "school-assets" if not set
SUPABASE_STORAGE_BUCKET=school-assets

# ── Application (Required) ───────────────────────────────────
# Used for password reset links, callbacks, etc.
# No trailing slash. Example: https://school-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── M-Pesa Daraja API (Optional — for v2 payment integration)─
# Get these from Safaricom Developer Portal: https://developer.safaricom.co.ke
# Set MPESA_ENV to "sandbox" for testing or "production" for live
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_C2B_RESPONSE_TYPE=Completed
MPESA_CALLBACK_BASE_URL=https://your-domain.com/api/mpesa/c2b

# M-Pesa: User IDs for system reconciliation
MPESA_DEFAULT_SCHOOL_ID=
MPESA_SYSTEM_USER_ID=

# ── Test Users (Optional — for seeding test data) ───────────
TEST_USER_PASSWORD=Test1234!
TEST_USER_EMAIL_DOMAIN=example.com

# ── Node Environment ────────────────────────────────────────
# Set automatically by Next.js (development / production)
# NODE_ENV=development
